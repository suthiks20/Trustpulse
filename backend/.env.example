DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
ENV=development
JWT_SECRET=change-me-to-a-long-random-string
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5176
RATE_LIMIT_STRICT=10/minute
RATE_LIMIT_DEFAULT=100/minute
MAX_UPLOAD_SIZE_MB=8
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=set-a-strong-password-then-run-scripts/seed_admin.py

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_BUCKET_NAME=enrolled-faces

RISK_WARNING_THRESHOLD=50
