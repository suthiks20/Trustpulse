{
  "manifest_version": 3,
  "name": "TrustPulse Continuous Auth",
  "version": "1.0.0",
  "description": "Continuous authentication: periodic face re-verification and site risk scoring while you browse protected sites.",
  "permissions": ["tabs", "activeTab", "storage", "alarms", "offscreen", "scripting"],
  "host_permissions": ["http://localhost:8000/*"],
  "optional_host_permissions": ["*://*/*"],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "TrustPulse",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options/options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
